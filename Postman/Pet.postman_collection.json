{
  "info": {
    "_postman_id": "ce4e0580-7c81-4b81-8914-6f988411660c",
    "name": "Pet",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "12111285"
  },
  "item": [
    {
      "name": "[POS] Get PET by valid ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test(\"Response params is valid showing pet details\", function () {",
              "    pm.expect(jsonData.id).to.not.be.null;",
              "    pm.expect(jsonData.category).to.have.property(\"id\");",
              "    pm.expect(jsonData.category).to.have.property(\"name\");",
              "    pm.expect(jsonData.name).to.not.be.null;",
              "    pm.expect(jsonData.photoUrls).to.have.length.above(0);",
              "    pm.expect(jsonData.tags).to.have.length.above(1);",
              "    pm.expect(jsonData.tags[0]).to.have.property(\"id\");",
              "    pm.expect(jsonData.tags[0]).to.have.property(\"name\");",
              "    pm.expect(jsonData.tags[1]).to.have.property(\"id\");",
              "    pm.expect(jsonData.tags[1]).to.have.property(\"name\");",
              "    pm.expect(jsonData.status).to.eql(\"available\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{test_env_host}}/pet/73943384",
          "host": [
            "{{test_env_host}}"
          ],
          "path": [
            "pet",
            "73943384"
          ]
        }
      },
      "response": []
    },
    {
      "name": "[NEG] Get PET by invalid ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "",
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test(\"Response params is invalid, showing error message\", function () {",
              "    pm.expect(jsonData.code).to.not.be.null;",
              "    pm.expect(jsonData.type).to.eql(\"error\");",
              "    pm.expect(jsonData.message).to.eql(\"Pet not found\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{test_env_host}}/pet/9999999999",
          "host": [
            "{{test_env_host}}"
          ],
          "path": [
            "pet",
            "9999999999"
          ]
        }
      },
      "response": []
    }
  ]
}