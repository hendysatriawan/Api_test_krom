  "item": [
    {
      "name": "[POS] create user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "",
              "//set variable username",
              "var username = pm.variables.replaceIn(\"{{$randomUserName}}\");",
              "pm.globals.set(\"username\", username);",
              "console.log(\"cek\", pm.globals.get(\"username\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test(\"response cotains code, type, and message\", function(){",
              "    pm.expect(jsonData.code).to.eql(200);",
              "    pm.expect(jsonData.type).to.not.be.null;",
              "    pm.expect(jsonData.message).to.not.be.null;",
              "})",
              "",
              "//ambil params dari request body & set global",
              "var requestBody = pm.request.body.raw;",
              "var parsedBody = JSON.parse(requestBody)",
              "pm.globals.set(\"username\", parsedBody.username);",
              "pm.globals.set(\"firstname\", parsedBody.firstName)",
              "pm.globals.set(\"lastname\", parsedBody.lastName);",
              "pm.globals.set(\"email\", parsedBody.email);",
              "pm.globals.set(\"password\", parsedBody.password);",
              "pm.globals.set(\"phone\", parsedBody.phone);",
              "pm.globals.set(\"userstatus\", parsedBody.userStatus)",
              "console.log(\"username2\", pm.globals.get(\"username\"));",
              "console.log(\"password\", pm.globals.get(\"password\"));",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": 3,\n  \"username\": \"{{username}}\",\n  \"firstName\": \"{{$randomFirstName}}\",\n  \"lastName\": \"{{$randomLastName}}\",\n  \"email\": \"{{username}}@yopmail.com\",\n  \"password\": \"Abcd1234\",\n  \"phone\": \"08{{$randomPhoneNumber}}\",\n  \"userStatus\": 0\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{test_env_host}}/user",
          "host": [
            "{{test_env_host}}"
          ],
          "path": [
            "user"
          ]
        }
      },
      "response": []
    },
